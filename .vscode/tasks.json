{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend (FastAPI)",
      "type": "shell",
      "command": "source .venv/bin/activate && uvicorn server.ws:app --host 0.0.0.0 --port 8000 --reload",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      }
    },
    {
      "label": "Run Frontend (Next.js)",
      "type": "shell",
      "command": "cd frontend && npm run dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      }
    },
    {
      "label": "Run All (Backend + Frontend)",
      "dependsOn": ["Run Backend (FastAPI)", "Run Frontend (Next.js)"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "source .venv/bin/activate && python -m pytest tests/ -v",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt && cd frontend && npm install",
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
